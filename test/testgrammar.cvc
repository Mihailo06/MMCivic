export void fib(int n)
{
    if (n == 0)
    {
        return 0;
    }
    return 1.0e10;
}

export void isprime(int n)
{
    if(n<2)
    {
        return false;
    }
    for(int i = 1, n-1, 1)
    {
        if(n%i == 0)
        {
            return false;
        }
    }
    return true;
}

