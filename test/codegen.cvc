export void castTests() {
    int srcInt = 42;
    float srcFloat = 42.5;
    bool srcBool = true;

    int int2Int = (int) srcInt;
    int float2Int = (int) srcFloat;
    int bool2Int = (int) srcBool;

    float int2Float = (float) srcInt;
    float float2Float = (float) srcFloat;
    float bool2Float = (float) srcBool;

    bool int2Bool = (bool) srcInt;
    bool float2Bool = (bool) srcFloat;
    bool bool2Bool = (bool) srcBool;
}

export int ifTest(bool x) {
    if (x) {
        return 42;
    }

    return 0;
}

export int ifElseTest(bool x) {
    if (x) {
        return 42;
    } else {
        return 0;
    }
}

export void whileTest(bool x) {
    int y = 0;
    while (x) {
        y = y + 1;
    }
}

export void doWhileTest() {
    int y = 0;
    do {
        y = y + 1;
    } while (y < 42);
}

export void procedurecallTest() {
    int x = 0;
    void innerFunc1() {
        innerFunc2(42); // should be isr
    }
    void innerFunc2(int y) {
        void innerFunc3() {
            innerFunc1(); // should be isrn 1
        }
        x = y;
    }

    innerFunc1(); // should be isrl
    doWhileTest(); // should be isrg
    printInt(42); // should be jsre
}

export void monopTest() {
    int x = -42;
    float y = -42.0;
    bool z = !false;
}
